# ============================================================================
# GeoBIM Stratum Platform - .gitignore
# ============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 가상환경
.venv/
venv/
env/
ENV/

# uv lock 파일은 추적 (재현성 위해)
# uv.lock 은 추적함

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# mypy / ruff
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Node / Frontend
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
dist/
dist-ssr/
.vite/
.vite-cache/
.vite-cache2/
*.local

# pnpm lock 은 추적
# pnpm-lock.yaml 은 추적함

# ---------------------------------------------------------------------------
# IDE / 에디터
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# 환경변수 (예시 파일은 추적)
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# ---------------------------------------------------------------------------
# 데이터 파일 (data/ 폴더와 seeds/data/ 하위 한정)
# 시추공 원본 PDF, CSV, JSON 등은 절대 커밋 금지
# ---------------------------------------------------------------------------
**/data/
backend/seeds/data/
*.pdf
*.hwpx
*.hwp
*.docx

# 단, 문서 디렉토리의 샘플은 예외 처리 (필요 시 docs/ 하위 명시적 추가)
!docs/**/*.pdf

# CSV/JSON 중 데이터 덤프만 제외 (설정 JSON은 추적 필요하므로 광범위 차단 안 함)
backend/seeds/data/*.csv
backend/seeds/data/*.json
**/dump_*.csv
**/dump_*.json

# ---------------------------------------------------------------------------
# Docker 볼륨 데이터 (혹시 로컬 마운트 시)
# ---------------------------------------------------------------------------
volumes/
postgres_data/
redis_data/

# ---------------------------------------------------------------------------
# 로그
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# Alembic 자동 생성 캐시
# ---------------------------------------------------------------------------
# alembic versions/ 폴더는 추적 (마이그레이션 파일은 코드)
